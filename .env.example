# Client key: use Publishable key (sb_publishable_...) or legacy anon JWT — both work the same.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key

# Server-only secret key for creating accounts (Settings → API → secret key)
SUPABASE_SERVICE_ROLE_KEY=your-secret-key

# Public site URL — use https://nchschessclub.com in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email notifications (Resend — https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=NCHS Chess Club <notifications@nchschessclub.com>

# Cron auth for Vercel scheduled event reminders (generate a random string)
CRON_SECRET=

# Web push (optional — generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@nchschessclub.com

# Database password (for CLI/migrations only — never expose in client code)
# SUPABASE_DB_PASSWORD=
